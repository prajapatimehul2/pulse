# --- Database ---
# Local dev (matches docker-compose.yml). Override in production with your RDS/EC2 Postgres URL.
DATABASE_URL="postgresql://habit:habit@localhost:5434/habit_tracker?schema=public"

# --- NextAuth ---
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-me-with-a-32-byte-random-string"
NEXTAUTH_URL="http://localhost:3000"

